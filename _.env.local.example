# Environment Variables Template
# Zkopírujte do .env.local a vyplňte vaše hodnoty

# Supabase (volitelné - pokud chcete používat databázi)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-key

# Resend Email Service (vyplňte svůj API klíč)
VITE_RESEND_API_KEY=re_3aebCfba_Azk2YvFozZhXZC7VK2CYWh4R

# Poznámky:
# - VITE_* prefix znamená, že proměnné jsou dostupné na klientu (Vite)
# - Všechny proměnné jsou veřejné - NEUCHOVÁVEJTE tajné klíče v VITE_* proměnných v produkci
# - Pro produkci byste měli mít backend endpoint pro bezpečné odesílání emailů
