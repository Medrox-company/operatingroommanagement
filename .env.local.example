# Environment Variables Template
# Zkopírujte do .env.local a vyplňte vaše hodnoty.
# POZOR: Nikdy necommitujte skutečné klíče do gitu!

# ── Supabase ────────────────────────────────────────────────
# Veřejné (dostanou se do klientského bundle):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Tajné (pouze server — service role obchází RLS!):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Autentizace ─────────────────────────────────────────────
# Náhodný řetězec (min. 32 znaků) pro podepisování session tokenů,
# např. `openssl rand -hex 32`:
SESSION_SECRET=

# Jen pro lokální vývoj bez HTTPS (vypne Secure cookie):
# ALLOW_INSECURE_COOKIE=1
# Jen pokud aplikace běží v iframe (např. v0 preview):
# COOKIE_SAMESITE_NONE=1

# ── E-maily (Resend) ────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=notifikace@vase-domena.cz
